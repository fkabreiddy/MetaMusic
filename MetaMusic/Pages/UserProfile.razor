@page "/user"


<MudItem Style="margin-top: 60px;margin-bottom: 60px;">
    <MudGrid >
        <MudItem md="4" xxl="4" xl="4" lg=4 xs=12 sm="12">
            <MudContainer Style="display: flex; flex-direction: column; gap:20px; justify-content:center; align-items: center; ">
                <MudText Style="font-size: 25px; font-weight: bold" Color="Color.Error">Usuario</MudText>
                <MudText Style="font-size: 35px; white-space: nowrap; text-overflow: ellipsis; overflow: hidden; font-family: SourceSerif4;">“Breiddy Garcia”</MudText>
                <MudText Style="font-size: 12px; font-weight: bold" Color="Color.Error">Staff</MudText>
                <MudAvatar Style="height: 150px; width: 150px;"><MudImage src="https://th.bing.com/th/id/OIP.UgQzi6yAnGyBFUgYT-H0swHaHa?rs=1&pid=ImgDetMain"></MudImage></MudAvatar>

               

                <div style="display: flex; justify-content: space-between; align-items: center; gap: 20px; margin-bottom: 15px;">
                    <MudText Style="font-size: 13px; font-weight: bold" Color="Color.Error">Correo</MudText>
                    <MudText Style="font-size: 15px;white-space: nowrap; text-overflow: ellipsis; overflow: hidden; font-family: SourceSerif4;">breiddysubzero@gmail.com</MudText>
                </div

                 <MudDivider Style="margin-top: 20px; margin-bottom: 20px;"></MudDivider>
                    <MudText Style="font-size: 13px; font-weight: bold" Color="Color.Error">Biografia</MudText>
                    <MudText Align="Align.Center" Style="font-size: 12px; ">Soy Breiddy Garcia y soy estudiante de programacion y creador de esta app. Metamusic</MudText>
                

                <MudDivider Style="margin-top: 20px; margin-bottom: 20px;"></MudDivider>
                <MudCard>

                    <MudContainer Style="height: auto; width: 100%; background-color:#E74646; display: flex; border-radius: 9px; flex-direction: column; ">


                        <MudText  Align="Align.Center" Style="font-size: 20px; font-weight: bold; margin-bottom: 10px; margin-top: 20px; color:white;">EDITA TU PERFIL</MudText>

                        <MudTextField MaxLength="30" T="string" Adornment="Adornment.Start" Style="font-size: 12px; color: whitesmoke;  margin-bottom: 10px; border: dashed 1px whitesmoke;   width: 100% ; border-radius:10px; height: 50px; padding: 10px;" Variant="MudBlazor.Variant.Text" DisableUnderLine="true" Placeholder='Tu nuevo nombre aqui'></MudTextField>
                     
                        <MudTextField MaxLength="30" T="string" Adornment="Adornment.Start" Style="font-size: 12px; color: whitesmoke;  margin-bottom: 21px; border: dashed 1px whitesmoke;   width: 100% ; border-radius:10px; height: 50px; padding: 10px;" Variant="MudBlazor.Variant.Text" DisableUnderLine="true" Placeholder='Url de tu perfil'></MudTextField>
                           
                           
                        <MudChip Variant="MudBlazor.Variant.Filled" Color="Color.Surface" Style="font-size: 12px; margin-bottom: 15px; cursor: pointer;" Text="Guardar Cambios"></MudChip>
                       
                    </MudContainer>


                </MudCard>
                
            </MudContainer>
        </MudItem>


        <MudItem md="8" xxl="8" xl="8" lg="8" xs=12 sm="12" >

            <MudContainer Style="display: flex; gap: 10px; flex-direction: column; justify-content: space-between; align-items: center; width: 100%;">
              
               
                

                 <MudTabs Color="Color.Transparent" Rounded="true" HideSlider="true" AlwaysShowScrollButtons="false" MinimumTabWidth="100" Elevation="0" IconColor="Color.Secondary" ScrollIconColor="Color.Secondary" Centered="true" Style="font-size: 10px; width: 100%;  height: 100%; margin-bottom: 15px;margin-top: 30px; padding:0; " SliderColor="Color.Secondary">
    
                    
                        <MudTabPanel style="@($"""{(view == "Notas" ? "color:#E74646;" : "")}font-size: 12px; border-radius: 10px; font-weight: bold;""")" ShowCloseIcon=false @onclick='()=>{view = "Notas";}' Text="Notas">
                           <MudGrid Style="margin-top: 20px;">
                                @foreach (var album in albumesRock)
                                {
                                    <MudItem md="6" lg="6" xl="6" xxl="6" sm="12" xs="12">
                                        <MetaMusic.Pages.Common_Components.Nota ></MetaMusic.Pages.Common_Components.Nota>
                                    </MudItem>
                                }
                            </MudGrid>
                        </MudTabPanel>
                         <MudTabPanel style="@($"""{(view == "Reviews" ? "color:#E74646;" : "")}font-size: 12px; border-radius: 10px; font-weight: bold;""")" ShowCloseIcon=false @onclick='()=>{view = "Reviews";}' Text="Reviews">
                            <MudGrid Style="margin-top: 20px;">
                                @foreach (var album in albumesRock)
                                {
                                    <MudItem md="3" lg="3" xl="3" xxl="3" sm="6" xs="6">
                                        <MetaMusic.Pages.Common_Components.ReviewCard album="@album"></MetaMusic.Pages.Common_Components.ReviewCard>
                                    </MudItem>
                                }
                            </MudGrid>
                         </MudTabPanel>

                    

                </MudTabs>

               




           
            </MudContainer>
        </MudItem>
    </MudGrid>
</MudItem>

@code {
    public static Album album1 { get; set; } = new() { nombre = "Solar Power", Autores = "Lorde", calificacion = 6, portada = "https://i.scdn.co/image/ab67616d0000b27336615a0a60523dd62135ab3a", genero = "Alternativo" };
    public static Album album2 { get; set; } = new() { nombre = "Melodrama", Autores = "Lorde", calificacion = 10, portada = "https://i.scdn.co/image/ab67616d0000b273f8553e18a11209d4becd0336", genero = "Alternativo" };
    public static Album album3 { get; set; } = new() { nombre = "Pure Heroine", Autores = "Lorde", calificacion = 8, portada = "https://i.scdn.co/image/ab67616d0000b273187331e276c898d39764cc98", genero = "Alternativo" };

    public static List<Album> albumesRock = new List<Album>(){
        album1,
        album2,
        album3,

    };
    public static Track track1 = new Track() { Titulo = "Royals", Duracion = TimeSpan.FromMinutes(3).Add(TimeSpan.FromSeconds(27)), Album = album3, Calificacion = 8, };
    public static Track track2 = new Track() { Titulo = "Green Light", Duracion = TimeSpan.FromMinutes(6).Add(TimeSpan.FromSeconds(22)), Album = album2, Calificacion = 10, };
    public static Track track3 = new Track() { Titulo = "Stoned at the nail salon", Duracion = TimeSpan.FromMinutes(8).Add(TimeSpan.FromSeconds(2)), Album = album1, Calificacion = 7, };
    public static Track track4 = new Track() { Titulo = "Tennis Court", Duracion = TimeSpan.FromMinutes(6).Add(TimeSpan.FromSeconds(30)), Album = album3, Calificacion = 9, };
    public static Track track5 = new Track() { Titulo = "The Louvre", Duracion = TimeSpan.FromMinutes(4).Add(TimeSpan.FromSeconds(15)), Album = album2, Calificacion = 9, };
    public static Track track6 = new Track() { Titulo = "Hard Feelings", Duracion = TimeSpan.FromMinutes(6).Add(TimeSpan.FromSeconds(21)), Album = album2, Calificacion = 8, };

    public List<Track> Tracks = new List<Track>(){

        track1,
        track2,
        track3,
        track4,
        track5,
        track6,
    };


    public string view = "Reviews";
}
