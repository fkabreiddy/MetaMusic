@page "/user/{useremail}"

@if(!userDataLoaded)
{
    <MudOverlay LightBackground=true Absolute="true" Visible=true Style="border-radius: 10px;">
        <div style="border-radius: 10px; display:flex; gap: 10px; align-items: center; flex-direction: column; justify-content: center;">
            @if (theme.IsDark())
            {
                <MudImage Src="/meta-logo-white.png" Style="width: 50px; width: 50px;"></MudImage>
            }
            else
            {
                <MudImage Src="/meta-logo.png" Style="width: 50px; width: 50px;"></MudImage>
            }
           

            <MudText Align="Align.Center" GutterBottom="true" Style="font-size: 15px; font-weight: bold;  margin-bottom: 15px;" Color="Color.Primary">Cargando Datos</MudText>

        </div>

    </MudOverlay>

}
else
{
    <BlazorAnimation.Animation Effect="BlazorAnimation.Effect.FadeIn" Speed="BlazorAnimation.Speed.Faster" Delay="TimeSpan.FromSeconds(1)">
        <MudItem Style="margin-top: 60px;margin-bottom: 60px;">
            <MudGrid>
                <MudItem md="4" xxl="4" xl="4" lg=4 xs=12 sm="12" Style=" border-radius: 10px;">
                    <MudContainer Style="display: flex; flex-direction: column; gap:20px; justify-content:center; align-items: center; ">
                        <MudText Style="font-size: 25px; font-weight: bold" Color="Color.Error">Usuario</MudText>
                        <MudText Style="font-size: 35px;   overflow: hidden; font-family: SourceSerif4;">“@Usuario.Nombre”</MudText>
                        @if(Usuario.Rol.Tipo != "Normal")
                        {
                            <MudText Style="font-size: 12px; font-weight: bold" Color="Color.Error">@Usuario.Rol.Tipo</MudText>
                        }
                     
                        <MudAvatar Style="height: 150px; width: 150px;border: dashed 2px;margin: 10px;"><MudImage src="@Usuario.FotoDePerfil"></MudImage></MudAvatar>



                        <div style="display: flex; justify-content: space-between; align-items: center; gap: 21px; margin-bottom: 15px;">
                            <MudText Style="font-size: 13px; font-weight: bold" Color="Color.Error">Correo </MudText>
                            <MudText Style="font-size: 15px;white-space: nowrap; text-overflow: ellipsis; overflow: hidden; font-family: SourceSerif4;">@Usuario.Correo</MudText>
                        </div>
                        <MudDivider Style="margin-top: 20px; margin-bottom: 20px;"></MudDivider>
                        <MudText Style="font-size: 13px; font-weight: bold" Color="Color.Error">Biografia</MudText>
                        <MudText Align="Align.Center" Style="font-size: 12px; ">@Usuario.Biografia</MudText>

                        @if(UsuarioActual.Id == Usuario.Id)
                        {
                            <MudDivider Style="margin-top: 20px; margin-bottom: 20px;"></MudDivider>
                            <MudCard>

                                <MudContainer Style="height: auto; width: 100%; display: flex; border-radius: 9px; flex-direction: column; ">


                                    <MudText Align="Align.Center" Style="font-size: 20px; font-weight: bold; margin-bottom: 10px; margin-top: 20px; ">EDITA TU PERFIL</MudText>

                                    <MudTextField @bind-Value="Usuario.Nombre" MaxLength="30" T="string" Adornment="Adornment.Start" Style="font-size: 12px;  margin-bottom: 10px; border: dashed 1px;   width: 100% ; border-radius:10px; height: 50px; padding: 10px;" Variant="MudBlazor.Variant.Text" DisableUnderLine="true" Placeholder='Tu nuevo nombre aqui'></MudTextField>

                                    <MudTextField @bind-Value="Usuario.FotoDePerfil" T="string" Adornment="Adornment.Start" Style="font-size: 12px;    border: dashed 1px ;   width: 100% ; border-radius:10px; height: 50px; padding: 10px;" Variant="MudBlazor.Variant.Text" DisableUnderLine="true" Placeholder='Url de tu perfil'></MudTextField>

                                    <MudTextField @bind-Value="Usuario.Biografia" MaxLength="100" T="string" Adornment="Adornment.Start" Style="font-size: 12px;   margin-bottom: 21px; border: dashed 1px ;   width: 100% ; border-radius:10px; height: 50px; padding: 10px;" Variant="MudBlazor.Variant.Text" DisableUnderLine="true" Placeholder='Biografia'></MudTextField>
                                    @if(GuardandoCambios)
                                    {
                                       <div style="display: flex; justify-content: center; align-items: center;">
                                                                                   <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Error"></MudProgressCircular>

                                       </div>

                                    }
                                    else

                                    {
                                        <div style="display: flex; justify-content: center; align-items: center;">
                                            <MudChip Variant="MudBlazor.Variant.Filled" Color="Color.Surface" @onclick="ModificarUsuario" Style="font-size: 12px; margin-bottom: 15px; cursor: pointer;" Text="Guardar Cambios"></MudChip>

                                        </div>
                                    }

                                </MudContainer>


                            </MudCard>
                        }
                      

                    </MudContainer>
                </MudItem>


                <MudItem md="8" xxl="8" xl="8" lg="8" xs=12 sm="12">

                    <MudContainer Style="display: flex; gap: 10px; flex-direction: column; justify-content: space-between; align-items: center; width: 100%;">




                        <MudTabs DisableRipple=true Color="Color.Transparent" Rounded="true" HideSlider="true" AlwaysShowScrollButtons="false" MinimumTabWidth="100" Elevation="0" IconColor="Color.Secondary" ScrollIconColor="Color.Secondary" Centered="true" Style="font-size: 10px; width: 100%;  height: 100%; margin-bottom: 15px;margin-top: 30px; padding:0; " SliderColor="Color.Secondary">

                            <AuthorizeView >
                                <Authorized >
                                    @if(Usuario.Id == UsuarioActual.Id && Usuario.Rol.Tipo == "Staff")
                                    {
                                        <MudTabPanel style="@($"""{(view == "Reviews" ? "color:#E74646;" : "")}font-size: 12px; border-radius: 10px; font-weight: bold;""")" ShowCloseIcon=false @onclick='()=>{view = "Reviews";}' Text="Reviews">
                                            <MudGrid Style="margin-top: 20px;">
                                                @foreach (var album in albumesRock)
                                                {
                                                    <MudItem md="3" lg="3" xl="3" xxl="3" sm="6" xs="6">
                                                        <MetaMusic.Pages.Common_Components.ReviewCard album="@album"></MetaMusic.Pages.Common_Components.ReviewCard>
                                                    </MudItem>
                                                }
                                            </MudGrid>
                                        </MudTabPanel>
                                        <MudTabPanel style="@($"""{(view == "Peticiones" ? "color:#E74646;" : "")}font-size: 12px; border-radius: 10px; font-weight: bold;""")" ShowCloseIcon=false @onclick='()=>{view = "Peticiones";}' Text="Peticiones">
                                            <MudText Align="Align.Center" Style="font-size: 12px; margin-top: 20px; opacity: 0.7; margin-bottom: 5px;">Las Peticiones se eliminan cuando se eliminan automaticamente cuando se agregue el contenido.</MudText>
                                            <MudGrid Style="margin-top: 20px;" Spacing="3">
                                                @foreach (var peticion in peticiones)
                                                {
                                                    <MudItem md="12" lg="12" xl="12" xxl="12" sm="12" xs="12">
                                                        <MetaMusic.Pages.Common_Components.NuevaPeticion Peticion="peticion"></MetaMusic.Pages.Common_Components.NuevaPeticion>

                                                    </MudItem>
                                                }
                                            </MudGrid>
                                        </MudTabPanel>
                                        <MudTabPanel style="@($"""{(view == "Reportes" ? "color:#E74646;" : "")}font-size: 12px; border-radius: 10px; font-weight: bold;""")" ShowCloseIcon=false @onclick='()=>{view = "Reportes";}' Text="Reportes">
                                            <MudGrid Style="margin-top: 20px;" Spacing="3">
                                                @foreach (var album in albumesRock)
                                                {
                                                    <MudItem md="3" lg="3" xl="3" xxl="3" sm="6" xs="6">
                                                        <MetaMusic.Pages.Common_Components.ReviewCard album="@album"></MetaMusic.Pages.Common_Components.ReviewCard>
                                                    </MudItem>
                                                }
                                            </MudGrid>
                                        </MudTabPanel>

                                    }
                                </Authorized>
                            </AuthorizeView>
                            <MudTabPanel style="@($"""{(view == "Notas" ? "color:#E74646;" : "")}font-size: 12px; border-radius: 10px; font-weight: bold;""")" ShowCloseIcon=false @onclick='()=>{view = "Notas";}' Text="Notas">
                                <MudGrid Style="margin-top: 20px;">
                                    @foreach (var album in albumesRock)
                                    {
                                        <MudItem md="6" lg="6" xl="6" xxl="6" sm="12" xs="12">
                                            <MetaMusic.Pages.Common_Components.Nota ReportButton=false></MetaMusic.Pages.Common_Components.Nota>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </MudTabPanel>

                            <MudTabPanel style="@($"""{(view == "Siguiendo" ? "color:#E74646;" : "")}font-size: 12px; border-radius: 10px; font-weight: bold;""")" ShowCloseIcon=false @onclick='()=>{view = "Siguiendo";}' Text="Siguiendo">
                                <MudGrid Style="margin-top: 20px;">
                                    @foreach (var album in albumesRock)
                                    {
                                        <MudItem md="6" lg="6" xl="6" xxl="6" sm="12" xs="12">
                                            <MetaMusic.Pages.Common_Components.Nota ReportButton=false></MetaMusic.Pages.Common_Components.Nota>
                                        </MudItem>
                                    }
                                </MudGrid>
                            </MudTabPanel>

                        </MudTabs>







                    </MudContainer>
                </MudItem>
            </MudGrid>
        </MudItem>
    </BlazorAnimation.Animation>
}


@functions{

    protected override async Task OnParametersSetAsync()
    {
        userDataLoaded = false;
        await GetCurrentUser();
        await GetUser();
        userDataLoaded = true;

        StateHasChanged();
    }
    public async Task ModificarUsuario()

    {
        GuardandoCambios = true;
        var r = await userService.Modificar(UsuarioActual.ToRequest());

        if(r.Success && r.Data is not null)
        {
            UsuarioActual = r.Data;
            Usuario = r.Data;

            GuardandoCambios = false;
            StateHasChanged();
            await JSR.InvokeVoidAsync("scrollHaciaInicio");
        }
    }
    protected override async Task OnInitializedAsync()
    {
        userDataLoaded = false;
        await GetCurrentUser();
        await GetUser();
        userDataLoaded = true;

        StateHasChanged();
    }


    public async Task GetCurrentUser()
    {

        var r = await userService.ConsultarUsuarioActual();
        if (r.Success == true && r.Data is not null)
        {

            UsuarioActual = r.Data;

            StateHasChanged();
        }



    }
    public async Task GetUser()
    {

        var r = await userService.ConsultarUsuario(useremail);
        if (r.Success == true && r.Data is not null)
        {

            Usuario = r.Data;
           
            StateHasChanged();
        }



    }

  
}
@code {
    [Parameter] public string useremail { get; set; } = "";
    public UsuarioResponse UsuarioActual { get; set; } = new UsuarioResponse();
    public UsuarioResponse Usuario { get; set; } = new UsuarioResponse();
    public bool userDataLoaded = false;
    public bool GuardandoCambios = false;



    public static Album album1 { get; set; } = new() { nombre = "Solar Power", Autores = "Lorde", calificacion = 6, portada = "https://i.scdn.co/image/ab67616d0000b27336615a0a60523dd62135ab3a", genero = "Alternativo" };
    public static Album album2 { get; set; } = new() { nombre = "Melodrama", Autores = "Lorde", calificacion = 10, portada = "https://i.scdn.co/image/ab67616d0000b273f8553e18a11209d4becd0336", genero = "Alternativo" };
    public static Album album3 { get; set; } = new() { nombre = "Pure Heroine", Autores = "Lorde", calificacion = 8, portada = "https://i.scdn.co/image/ab67616d0000b273187331e276c898d39764cc98", genero = "Alternativo" };

    public static List<Album> albumesRock = new List<Album>(){
        album1,
        album2,
        album3,

    };

    public static Artista artista1 = new Artista() { Foto = "https://th.bing.com/th/id/R.7d9919c0534512958384b626ef4e0bc4?rik=FRxU3HvMAgwmBQ&pid=ImgRaw&r=0", Nombre = "Billie Eilish" };
    public static Track track1 = new Track() { Titulo = "Royals", Duracion = TimeSpan.FromMinutes(3).Add(TimeSpan.FromSeconds(27)), Album = album3, Calificacion = 8, };
    public static Track track2 = new Track() { Titulo = "Green Light", Duracion = TimeSpan.FromMinutes(6).Add(TimeSpan.FromSeconds(22)), Album = album2, Calificacion = 10, };
    public static Track track3 = new Track() { Titulo = "Stoned at the nail salon", Duracion = TimeSpan.FromMinutes(8).Add(TimeSpan.FromSeconds(2)), Album = album1, Calificacion = 7, };
    public static Track track4 = new Track() { Titulo = "Tennis Court", Duracion = TimeSpan.FromMinutes(6).Add(TimeSpan.FromSeconds(30)), Album = album3, Calificacion = 9, };
    public static Track track5 = new Track() { Titulo = "The Louvre", Duracion = TimeSpan.FromMinutes(4).Add(TimeSpan.FromSeconds(15)), Album = album2, Calificacion = 9, };
    public static Track track6 = new Track() { Titulo = "Hard Feelings", Duracion = TimeSpan.FromMinutes(6).Add(TimeSpan.FromSeconds(21)), Album = album2, Calificacion = 8, };

    public List<Track> Tracks = new List<Track>(){

        track1,
        track2,
        track3,
        track4,
        track5,
        track6,
    };


    public static Peticion peticion1 = new Peticion() { Album = album1 };
    public static Peticion peticion2 = new Peticion() { Artista = artista1 };
    public List<Peticion> peticiones = new List<Peticion>() { peticion1, peticion2 };


    public string view = "Notas";
}
