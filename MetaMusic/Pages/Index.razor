@page "/"
<style>
    .review-text-card{
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
       
    }

    .review-card{
        cursor: pointer;
    }

    .review-card:hover{
            border: thin 1px #E74646;
        
    }
</style>
<MudItem Style="margin-top: 30px;">
    <MudGrid Style="display: flex; align-items: center; ">
        <MudItem md="8" lg="8" xl="8" xxl="8" sm="12" xs="12">
           
               <MetaMusic.Pages.Common_Components.LoMasReciente></MetaMusic.Pages.Common_Components.LoMasReciente>
            
        </MudItem>
        <MudItem md="4" lg="4" xl="4" xxl="4" sm="12" xs="12" Style="margin-top: 45px;">
  
            <MetaMusic.Pages.Common_Components.NuevaPropuesta></MetaMusic.Pages.Common_Components.NuevaPropuesta>
        </MudItem>
       
    </MudGrid>
</MudItem>
<BlazorAnimation.Animation Effect="BlazorAnimation.Effect.FadeIn" Speed="BlazorAnimation.Speed.Faster" Delay="TimeSpan.FromSeconds(1)">
    <MudDivider Style="margin-top: 40px; margin-bottom: 40px;  "></MudDivider>

    <ReviewOfTheMonth></ReviewOfTheMonth>

</BlazorAnimation.Animation>
<BlazorAnimation.Animation Effect="BlazorAnimation.Effect.FadeIn" Speed="BlazorAnimation.Speed.Faster" Delay="TimeSpan.FromSeconds(1)">
    <MudDivider Style="margin-top: 40px; margin-bottom: 40px;  "></MudDivider>
    <SongReviewOfTheMonth></SongReviewOfTheMonth>

</BlazorAnimation.Animation>

<BlazorAnimation.Animation Effect="BlazorAnimation.Effect.FadeIn" Speed="BlazorAnimation.Speed.Faster" Delay="TimeSpan.FromSeconds(3)">
    <MudDivider Style="margin-top: 40px; margin-bottom: 40px;"></MudDivider>

    <Explora></Explora>
</BlazorAnimation.Animation>



