
<MudGrid Style="display: flex; align-items: center; justify-content: center;" Justify="Justify.Center">
    <MudItem md="12" sm="12" xl="12" xxl="12" xs="12" lg="12" Style="display: flex; align-items: center; justify-content: center;">
        <MudAvatar Style="height: 120px; width: 120px;">
            <MudImage src="@Usuario.FotoDePerfil"></MudImage>
        </MudAvatar>
    </MudItem>
    <MudItem md="12" sm="12" xl="12" xxl="12" xs="12" lg="12">
        <MudContainer Style="display: flex; flex-direction: column; display: flex; align-items: center; justify-content: center;gap:15px;">
            <MudLink Href="@($"/user/{Usuario.CorreoNormalizado}")" Style="font-size: 15px; font-weight: bold;">@Usuario.Nombre </MudLink>
                

            @if(Usuario.Rol.Tipo == "Staff")
            {
                <MudText Style="font-size: 10px; font-weight: bold;" Color="Color.Error">STAFF </MudText>
            }
            

           
            <MudText Style="font-size: 10px; margin-top: 10px; margin-bottom: 10px;">@("@" + Usuario.CorreoNormalizado)  </MudText>

           
        </MudContainer>
    </MudItem>
</MudGrid>
@code {
    [Parameter] public UsuarioResponse Usuario { get; set; } = new UsuarioResponse();
}
