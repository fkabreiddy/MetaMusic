<MudGrid Style="display: flex; align-items: center; justify-content: center;">
    <MudItem md="4" sm="4" xl="4" xxl="4" xs="4" lg="4">
        <MudAvatar Style="height: 120px; width: 120px;">
            <MudImage src="@Artista.Foto_Perfil"></MudImage>
        </MudAvatar>
    </MudItem>
    <MudItem md="8" sm="8" xl="8" xxl="8" xs="8" lg="8">
        <MudContainer Style="display: flex; flex-direction: column;">
            <MudLink Href="@($"/artist/{@Artista.SpotifyId}")" Style="font-size: 15px; font-weight: bold;">@Artista.Nombre </MudLink>
                <MudText Style="font-size: 10px; font-weight: bold;" Color="Color.Error">@Artista.GenerosMusicales[0].Genero?.Nombre / @Artista.GenerosMusicales[1].Genero?.Nombre </MudText>
                <MudText Style="font-size: 10px; margin-top: 10px; margin-bottom: 10px;">@Artista.Suscriptores.Count() Suscriptores  </MudText>

                <AuthorizeView>
                    <Authorized>

                        @if(Artista.Suscriptores.Any(r => r.Usuario.Id == UserId))
                        {
                            <MudChip @onclick="async ()=>{await DeSuscribirse(Artista);}" Style="font-size: 10px;  width: 50%; font-weight: bold;cursor: pointer; margin-left: -5px;" Size="Size.Small" Variant="Variant.Filled">
                                @if (suscribiendo)
                                {
                                    <MudProgressCircular Style="width: 20px; height: 20px" Color="Color.Error" Indeterminate=true></MudProgressCircular>
                                }
                                else
                                {
                                    @("Suscrito")
                                }

                            </MudChip>
                        }
                        else
                        {
                            <MudChip @onclick="async ()=>{await Suscribirse(Artista);}" Style="font-size: 10px;  border: dashed 1px red; width: 50%; font-weight: bold;cursor: pointer; margin-left: -5px;" Size="Size.Small" Variant="Variant.Text" Color="Color.Error">
                                @if (suscribiendo)
                                {
                                    <MudProgressCircular Style="width: 20px; height: 20px" Color="Color.Error" Indeterminate=true></MudProgressCircular>
                                }
                                else
                                {
                                    @("Suscribirse")
                                }

                            </MudChip>
                        }
                        

                    </Authorized>
                </AuthorizeView>
        </MudContainer>
    </MudItem>
</MudGrid>
@functions{

    public async Task Suscribirse(ArtistaResponse artista){
        suscribiendo = true;
        var x = await artistaService.Suscribirse(artista);

        if(x.Data is not null)
        {
            Artista = x.Data;
            StateHasChanged();
        }
        suscribiendo = false;
    }

    public async Task DeSuscribirse(ArtistaResponse artista)
    {
        suscribiendo = true;
        var x = await artistaService.DesSuscribirse(artista);

        if (x.Data is not null)
        {
            Artista = x.Data;
            StateHasChanged();
        }
        suscribiendo = false;
    }
}
@code {
    [Parameter] public ArtistaResponse Artista { get; set; } = new ArtistaResponse();
    [Parameter] public int UserId { get; set; }
    public bool suscribiendo = false;
}
