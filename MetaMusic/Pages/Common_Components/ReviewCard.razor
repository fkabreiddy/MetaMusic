<style>
    .review-text-card {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

        <MudContainer Style="height: 300px; display: flex; flex-direction: column; gap: 20px;  ">
            

            <div class="review-text-card">
                <div style="display: flex; align-items: center; justify-content: center; ">
                    <MudAvatar Square="true" Rounded="false" Style="border-radius: 10px;height: 150px; width: 150px; margin-bottom: 20px; margin-top: 20px; "><MudImage Fluid="true" ObjectFit="ObjectFit.Cover" src="@album.portada" Style="height:100%;border-radius: 10px; width: 100%;  " /></MudAvatar>

                </div>
                <MudText Align="Align.Center" Style="font-size: 12px; font-weight: bold;  ">@album.nombre</MudText>

            </div>
             <MudText Align="Align.Center" Style="font-size: 12px; font-weight: bold; opacity: 0.7; " Color="Color.Error">@album.Autores</MudText>
               
                

         </MudContainer>
    

@code {
    

    [Parameter]
    public Album album { get; set; } = new Album();
}
