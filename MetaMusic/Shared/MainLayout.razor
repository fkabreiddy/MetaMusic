@inherits LayoutComponentBase
<MudThemeProvider  IsDarkMode=@IsDarkMode Theme="ThemeCustom"/>
<MudDialogProvider />
<MudSnackbarProvider />
<PageTitle>MetaMusic</PageTitle>
<style>
     .meta-nav-button {
    }

       .meta-nav-button:hover {
            color: #E74646;
        }

        ::-webkit-scrollbar {
    width: 2px;
    border-radius: 10px;
}

    .navbar-container {
        
    }

    .mostrar {
        border-bottom: 1px solid #E74646;
    }



    /* ::-webkit-scrollbar {
        width: 0px;
        background: transparent; /* make scrollbar transparent */
    } */

    ::-webkit-scrollbar-thumb {
        width: 2px;
        background: #E74646; /* make scrollbar transparent */
    }

    ::-webkit-scrollbar-thumb {
        width: 2px;
        border-radius: 10px;
        background: #E74646; /* make scrollbar transparent */
    }


</style>
<div style="     width: calc( 100vw - 14px); ">
 
    <MudItem>
        <MudGrid>
            <MudItem md="12" sm="12" xs="12" xxl="12" lg="12" xl="12" Style="@($""" {(IsDarkMode ? "background-color:#000000;" : "background-color:#ffffff;")}; z-index: 10;""")">

                <MudContainer id="navbar" Class="@navbarclass" Style="@($""" {(IsDarkMode ? "background-color:#000000;" : "background-color:#ffffff;")}; z-index: 10;height: 80px; display: flex; justify-content: space-between; max-width: 100%; gap: 10px;position: fixed;""")">
                    <div style="display: flex; align-items: center; flex-direction: column;">

                        @if(IsDarkMode)
                        {
                            <MudImage Src="/meta-logo-white.png" Style="width: 50px; width: 50px;"></MudImage>
                        }
                        else
                        {
                            <MudImage Src="/meta-logo.png" Style="width: 50px; width: 50px;"></MudImage>
                        }
                     
                        <MudText Style="font-size: 10px; font-weight: bold;">M E T A M U S I C</MudText>
                    </div>
                    <div style="display: flex; align-items: center;  gap : 17px;">
                      


                         <MudMenu    Style="width: auto;" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">

                             <ActivatorContent>
                                <MudAvatar Style="height: 35px; width: 35px;  margin-right: 20px;"><MudImage Fluid="true" ObjectFit="ObjectFit.Cover" src="https://th.bing.com/th/id/OIP.UgQzi6yAnGyBFUgYT-H0swHaHa?rs=1&pid=ImgDetMain" Style="height:100%;border-radius: 10px; width: 100%;  " /></MudAvatar>

                             </ActivatorContent>
                             <ChildContent>
                                <MudPaper Outlined="true" Style="z-index: 999999; ">
                                    <MudContainer Style="max-height: 80vh; overflow: auto; margin-top: 10px;margin-bottom: 10px; ">
                                        <MudText Align="Align.Center" Style="font-size: 12px; opacity: 0.7; ">Acerca de ti</MudText>
                                        <MudDivider Class="mb-3 mt-3"></MudDivider>
                                        <MudMenuItem Disabled=true Style="border-radius: 10px;">
                                            <div style="display:flex; justify-content: space-between; align-items: center; gap: 15px;">
                                                <MudText Style="font-size: 12px; font-weight: bold; opacity: 0.7; " Color="Color.Error">Nombre</MudText>
                                                <MudText Style="font-size: 12px;   ">Breiddy Garcia</MudText>
                                            </div>

                                        </MudMenuItem>


                                        <MudMenuItem Disabled=true Style="border-radius: 10px;">
                                            <div style="display:flex; justify-content: space-between; align-items: center; gap: 15px;">
                                                <MudText Style="font-size: 12px; font-weight: bold; opacity: 0.7; " Color="Color.Error">Rol</MudText>
                                                <MudText Style="font-size: 12px;   ">Staff</MudText>
                                            </div>

                                        </MudMenuItem>

                                        <MudDivider Class="mb-3 mt-3"></MudDivider>
                                        <MudText Align="Align.Center" Style="font-size: 12px; opacity: 0.7; ">Opciones</MudText>
                                        <MudDivider Class="mb-3 mt-3"></MudDivider>
                                        <MudMenuItem Style="border-radius: 10px;">
                                            <div style="display:flex; justify-content: space-between; align-items: center;">
                                                <MudText Style="font-size: 12px;   ">Ver perfil</MudText>
                                                <MudIcon Color="Color.Primary" Style="height:  15px; width: 15px;" Size="Size.Small" Icon="@Icons.Material.Rounded.Person"></MudIcon>
                                            </div>

                                        </MudMenuItem>
                                        <MudMenuItem Style="border-radius: 10px;">
                                            <div style="display:flex; justify-content: space-between; align-items: center;">
                                                <MudText Style="font-size: 12px;   ">Notificaciones</MudText>
                                                <MudIcon Color="Color.Primary" Style="height:  15px; width: 15px;" Size="Size.Small" Icon="@Icons.Material.Rounded.Notifications"></MudIcon>
                                            </div>

                                        </MudMenuItem>
                                       
                                        <MudMenuItem @onclick="()=>{theme.SetDarkTheme(!IsDarkMode);IsDarkMode = !IsDarkMode; }" Style="border-radius: 10px;">
                                            <div style="display:flex; justify-content: space-between; align-items: center;">
                                                <MudText Style="font-size: 12px;   ">Modo @(IsDarkMode ? "Claro" : "Oscuro")</MudText>
                                                
                                                <MudIcon   Style="height:  15px; width: 15px;" Size="Size.Small" Icon="@Icons.Material.Rounded.LightMode"></MudIcon>
                                            </div>

                                        </MudMenuItem>
                                        <MudMenuItem Style="border-radius: 10px;">

                                            <MudMenu ActivationEvent="MouseEvent.MouseOver" AnchorOrigin="Origin.CenterRight" TransformOrigin="Origin.CenterLeft" Dense>
                                                <ActivatorContent>
                                                    <div style="display:flex; justify-content: space-between; align-items: center; gap: 50px; align-items: center; ">
                                                        <MudText Color="Color.Error" Style="font-size: 12px;   ">Crear Conenido</MudText>
                                                        <MudIcon Color="Color.Error" Style="height:  12px; width: 12px; " Size="Size.Small" Icon="@Icons.Material.Rounded.ArrowForwardIos"></MudIcon>

                                                    </div>
                                                </ActivatorContent>

                                                <ChildContent>
                                                    <MudPaper Outlined="true" Style="z-index: 999999; ">
                                                        <MudContainer Style="max-height: 80vh; overflow: auto; margin-top: 10px;margin-bottom: 10px; ">

                                                            <MudMenuItem Style="border-radius: 9px;">
                                                                <div style="display:flex; justify-content: space-between; align-items: center; border-radius: 9px; ">
                                                                    <MudText Color="Color.Error" Style="font-size: 12px;   ">Agregar Artista</MudText>
                                                                </div>
                                                               
                                                             </MudMenuItem>
                                                            <MudMenuItem Style="border-radius: 9px;">
                                                                <div style="display:flex; justify-content: space-between; align-items: center;border-radius: 9px;">
                                                                    <MudText Color="Color.Error" Style="font-size: 12px;   ">Review de un Single</MudText>
                                                                </div>

                                                            </MudMenuItem>
                                                            <MudMenuItem Style="border-radius: 9px;">
                                                                <div style="display:flex; justify-content: space-between; align-items: center;border-radius: 9px;">
                                                                    <MudText Color="Color.Error" Style="font-size: 12px;   ">Review de un album</MudText>

                                                                </div>

                                                            </MudMenuItem>
                                                        </MudContainer>
                                                     </MudPaper>
                                                   
                                                </ChildContent>
                                            </MudMenu>
                                           

                                        </MudMenuItem>
                                       

                                        <MudDivider Class="mb-3 mt-3"></MudDivider>
                                        <MudMenuItem Style="border-radius: 10px; " Class="meta-nav-button">
                                            <div style="border-radius: 10px; display: flex; align-items: center; justify-content: space-between;">
                                                <MudText Style="font-size: 12px;   " Class="meta-nav-button">Cerrar Sesion</MudText>
                                                <MudIcon Color="Color.Error" Style="height:  15px; width: 15px;" Size="Size.Small" Icon="@Icons.Material.Rounded.ArrowBack"></MudIcon>

                                            </div>
                                            
                                      </MudMenuItem>


                                    </MudContainer>
                                   

                                </MudPaper>
                             </ChildContent>

                                                




                         </MudMenu>
                     

                        <MudText Class="meta-nav-button" @onclick='()=>{navManager.NavigateTo("/");}' Style="font-size: 13px; font-weight: bold; cursor:pointer;">HOME</MudText>

                        @if(IsDarkMode)
                        {
                            <MudTextField MaxLength="30" T="string" IconSize="Size.Small" AdornmentIcon="@Icons.Material.Rounded.Search" Adornment="Adornment.Start" Style="font-size: 12px;  margin-bottom: 20px;  font-weight:  bold; width: 25vw ;background-color: #191919;   border-radius:10px; height: 30px; padding: 10px;" Variant="Variant.Text" DisableUnderLine="true" Placeholder='Buscar'></MudTextField>

                        }
                        else
                        {
                                                    <MudTextField MaxLength="30" T="string" IconSize="Size.Small" AdornmentIcon="@Icons.Material.Rounded.Search" Adornment="Adornment.Start" Style="font-size: 12px;  margin-bottom: 20px;  font-weight:  bold; width: 25vw ;background-color: #EEEEEE;   border-radius:10px; height: 30px; padding: 10px;" Variant="Variant.Text" DisableUnderLine="true" Placeholder='Buscar'></MudTextField>
                            
                        }
                    </div>

                </MudContainer>
               
            </MudItem>

            



            <MudItem md="12" sm="12" xs="12" xxl="12" lg="12" xl="12" Style="margin-top: 4em; ">
                <MudContainer >
                  
                    @Body
                </MudContainer>


            </MudItem>

            

        </MudGrid>
       
    </MudItem>

    <MudTFootRow Style="position: static ; margin-bottom: 0;  display: flex; align-items: center; justify-content: center; width: calc( 100vw - 2px); gap: 10px; background-color: black; height: 60px; margin-top: 30px;">
        <MudText Align="Align.Center" Style="font-size: 30px; font-weight: bold;" Color="Color.Error">M E T A M U S I C</MudText>
    </MudTFootRow>


   

      
</div>

<script>
    document.addEventListener("scroll", function () {
        var elemento = document.getElementById("navbar");

        // Verificar si el scrollbar está en la parte superior
        if (window.scrollY >= 3) {
            elemento.classList.add("mostrar");
        } else {
            elemento.classList.remove("mostrar");
        }
    });
</script>

@code{
    private string navbarclass = "navbar-container";
    public bool IsDarkMode { get; set; } = true ;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if(firstRender)
        {
             await JSR.InvokeVoidAsync("agregarScrollListener");
        }
       
    }

    [JSInvokable]
    public void ManejarScroll(int scrollY)
    {
        // Verificar si el scrollbar está en la parte superior
        navbarclass = (scrollY == 0) ? "navbar-container" : "mostrar";
    }

    private MudTheme ThemeCustom => new()
        {


            Shadows = new Shadow()
            {

                Elevation = Enumerable.Repeat("0px", 30).ToArray()
            },
            Palette = new PaletteLight
            {
                Primary = "#1D1A31",
                Secondary = "#393E46",
                Surface = "#FDFDFD ",
                Background = "#FFFFFF ",
                Tertiary = "#164863",
                Error = "#E74646"





            },
            PaletteDark = new PaletteDark
            {

                Primary = "#f8f7f4",
                Secondary = "#f1f2f2",
                Tertiary = "#164863",
                Background = "#000000",
                Error = "#E74646",
                Surface = "#191919",






            },

            LayoutProperties = new LayoutProperties()
            {

                DefaultBorderRadius = "10px",


            },

            Typography = new Typography()
            {


                Default = new Default()
                {
                    FontFamily = new string[] { "Inter" },



                },
                Caption = new Caption()
                {
                    FontFamily = new string[]{"SourceSerif4"}
                }






            }


        };
}